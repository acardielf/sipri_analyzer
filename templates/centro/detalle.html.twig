{% extends 'base.html.twig' %}

{% set localidad = centro.localidad %}
{% set provincia = localidad.provincia %}
{% set isOcep = centro.id in constant('App\\Entity\\Centro::OCEP_OTROS_CENTROS') %}

{% block title %}{{ centro.nombre }} – Analizador SIPRI{% endblock %}

{% block main_content %}
<div class="page-header">
    <div class="container-fluid">
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_index') }}"><i class="bi bi-house-fill me-1"></i>Inicio</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_centros_index') }}">Centros</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_centros_provincia', { provincia: provincia.id }) }}">{{ provincia.nombre }}</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ centro.nombre }}</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <h2 class="mb-0">
                <i class="bi bi-building-fill me-2"></i>{{ centro.nombre }}
                {% if isOcep %}
                    <span class="badge ms-2" style="background:var(--sipri-accent);color:#fff;font-size:.75rem;vertical-align:middle">OCEP</span>
                {% endif %}
            </h2>
        </div>
        <p class="mb-0 mt-1" style="color:var(--sipri-muted);font-size:.9rem">
            <span class="badge-code me-1">{{ centro.id }}</span>
            {{ localidad.nombre }} · {{ provincia.nombre }}
        </p>
    </div>
</div>

<div class="container-fluid py-4 pb-5">

    {# ── Stats ────────────────────────────────────────────────────────────────── #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card-sipri text-center p-3" style="display:block">
                <div style="font-size:2rem;font-weight:800;color:var(--sipri-blue)">{{ totalPlazas }}</div>
                <div style="font-size:.82rem;color:var(--sipri-muted);text-transform:uppercase;letter-spacing:.04em">Total plazas</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card-sipri text-center p-3" style="display:block">
                <div style="font-size:2rem;font-weight:800;color:var(--sipri-blue-mid)">{{ totalEspecialidades }}</div>
                <div style="font-size:.82rem;color:var(--sipri-muted);text-transform:uppercase;letter-spacing:.04em">Especialidades</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card-sipri text-center p-3" style="display:block">
                <div style="font-size:1.4rem;font-weight:700;color:var(--sipri-blue)">{{ ultimoCurso ?? '–' }}</div>
                <div style="font-size:.82rem;color:var(--sipri-muted);text-transform:uppercase;letter-spacing:.04em">Último curso</div>
            </div>
        </div>
    </div>

    {# ── Plazas por curso ─────────────────────────────────────────────────────── #}
    {% if plazasByCurso is empty %}
    <div class="text-center py-5" style="color:var(--sipri-muted)">
        <i class="bi bi-building-x d-block fs-2 mb-2 opacity-50"></i>
        No hay plazas registradas para este centro.
    </div>
    {% else %}
        {% for cursoNombre, plazas in plazasByCurso %}
        <div class="mb-4">
            <div class="d-flex align-items-center gap-2 mb-2"
                 style="border-bottom:2px solid var(--sipri-border);padding-bottom:.5rem">
                <h5 class="mb-0" style="color:var(--sipri-blue);font-weight:700">
                    <i class="bi bi-calendar3 me-1"></i>{{ cursoNombre }}
                </h5>
                <span class="badge" style="background:var(--sipri-blue);color:#fff;font-size:.78rem">
                    {{ plazas|length }} plaza{{ plazas|length != 1 ? 's' }}
                </span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:.875rem">
                    <thead style="background:var(--sipri-bg)">
                        <tr>
                            <th>Fecha conv.</th>
                            <th>Especialidad</th>
                            <th>Tipo</th>
                            <th class="text-end">Nº</th>
                            <th>F. Cese</th>
                            <th class="text-end">Orden adj.</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for plaza in plazas %}
                        {% set tipoValue = plaza.tipo.value is defined ? plaza.tipo.value : plaza.tipo %}
                        <tr>
                            <td style="color:var(--sipri-muted);white-space:nowrap">
                                {{ plaza.convFecha ? plaza.convFecha|date('d/m/Y') : '–' }}
                            </td>
                            <td>
                                <span class="fw-semibold">{{ plaza.espNombre }}</span>
                                <span class="badge-code ms-1" style="font-size:.7rem">{{ plaza.espId }}</span>
                            </td>
                            <td>
                                <span class="badge {{ tipoValue == 'VACANTE' ? 'badge-vacante' : 'badge-sustitucion' }}">
                                    {{ tipoValue == 'VACANTE' ? 'Vacante' : 'Sustitución' }}
                                </span>
                            </td>
                            <td class="text-end">{{ plaza.numero }}</td>
                            <td style="color:var(--sipri-muted);white-space:nowrap">
                                {{ plaza.fechaPrevistaCese ? plaza.fechaPrevistaCese|date('d/m/Y') : '–' }}
                            </td>
                            <td class="text-end font-monospace">
                                {% if plaza.adjOrden is not null %}
                                    {{ plaza.adjOrden }}
                                {% else %}
                                    <span style="color:var(--sipri-muted)">–</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endfor %}
    {% endif %}

</div>
{% endblock %}
