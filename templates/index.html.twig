{% extends 'base.html.twig' %}

{% block title %}Analizador SIPRI{% endblock %}
{% block header %}{% endblock %}

{% block main_content %}
<div class="hero-section">
    <div class="container">
        <p class="mb-2" style="font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.45)">
            <i class="bi bi-bar-chart-fill me-1" style="color:var(--sipri-accent)"></i>Analizador de convocatorias de SIPRI en Andalucía
        </p>
        <h1>¿Cuándo voy a currar?</h1>
        <p class="lead">
            Histórico de convocatorias de interinidades docentes en Andalucía desde el curso 2018/2019.
            Consulta plazas por especialidad, posiciones de bolsa y evolución por curso.
        </p>
        <a href="{{ path('app_lista_cuerpos') }}" class="btn-hero mb-5">
            <i class="bi bi-search"></i> Explorar especialidades
        </a>

        <div class="row g-3 justify-content-center mt-1">
            <div class="col-12 col-sm-auto">
                <div class="metric-card">
                    <div class="metric-label"><i class="bi bi-clock me-1"></i>Datos actualizados a</div>
                    <div class="metric-value">{{ "now"|date("d/m/Y") }}</div>
                </div>
            </div>
            <div class="col-12 col-sm-auto">
                <div class="metric-card">
                    <div class="metric-label"><i class="bi bi-file-earmark-text me-1"></i>Última convocatoria analizada</div>
                    <div class="metric-value">nº {{ convocatoria.id }} &mdash; {{ convocatoria.fecha|date("d/m/Y") }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 text-center">
            <p class="text-muted">
                Los datos proceden de los anexos PDF publicados en el SIPRI oficial y se procesan de forma automática.
                Se recogen sustituciones y vacantes sobrevenidas, sin incluir vacantes informatizadas.
            </p>
            <p>
                <a href="https://www.mapavacantesandalucia.es/" target="_blank" class="text-muted small">
                    <i class="bi bi-box-arrow-up-right"></i> Mapa de vacantes (recurso externo)
                </a>
                &nbsp;·&nbsp;
                <a href="{{ path('app_faq') }}" class="text-muted small">
                    <i class="bi bi-question-circle"></i> Preguntas frecuentes
                </a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
