{% extends 'base.html.twig' %}

{% block title %}{{ cuerpo.id }} – {{ cuerpo.nombre }}{% endblock %}

{% block main_content %}
<div class="page-header">
    <div class="container-fluid">
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_lista_cuerpos') }}"><i class="bi bi-collection-fill me-1"></i>Cuerpos</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ cuerpo.id }}</li>
            </ol>
        </nav>
        <h2>
            <span class="badge-code me-2">{{ cuerpo.id }}</span>
            {{ cuerpo.nombre }}
        </h2>
    </div>
</div>

<div class="container-fluid pb-5"
     data-controller="search pinned-cards filtro-historicas">

    {# ── Favoritas de este cuerpo ──────────────────────────────────────────── #}
    <div data-pinned-cards-target="seccion" class="d-none mb-4">
        <div class="pinned-section-header">
            <i class="bi bi-star-fill pinned-section-star"></i>
            <span class="pinned-section-title">Mis favoritas en este cuerpo</span>
        </div>
        <div class="row g-3" data-pinned-cards-target="lista"></div>
        <hr class="pinned-section-sep">
    </div>

    {# ── Buscador de especialidades ────────────────────────────────────────── #}
    <div class="row mb-4 align-items-center">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="search"
                       class="form-control search-input"
                       placeholder="Filtrar por código o denominación…"
                       autocomplete="off"
                       autofocus
                       data-search-target="input"
                       data-action="input->search#filter">
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-8 mt-2 mt-md-0 text-md-end search-count d-flex align-items-center justify-content-md-end gap-3 flex-wrap">
            {% set countHistoricas = especialidades|filter(e => e.id not in activasIds)|length %}
            {% if countHistoricas > 0 %}
                <button class="btn btn-sm btn-outline-secondary"
                        data-filtro-historicas-target="btn"
                        data-action="filtro-historicas#toggle">
                    Ver históricas ({{ countHistoricas }})
                </button>
            {% endif %}
            <span><span data-search-target="count">{{ especialidades|length }}</span> especialidades</span>
        </div>
    </div>

    {# ── Grid de especialidades ────────────────────────────────────────────── #}
    <div class="row g-3" data-pinned-cards-target="grid">
        {% for especialidad in especialidades %}
        {% set esHistorica = especialidad.id not in activasIds %}
        <div class="col-12 col-md-6 col-xl-4"
             data-search-target="item"
             data-search-terms="{{ especialidad.id|lower }} {{ especialidad.nombre|lower }}"
             {% if esHistorica %}data-historica="true"{% endif %}>
            <div class="card-sipri-wrap">
                <a href="{{ path('app_especialidad_index', { especialidad: especialidad.id }) }}" class="card-sipri">
                    <span class="card-code">{{ especialidad.id }}</span>
                    <span class="card-name">{{ especialidad.nombre }}{% if esHistorica %}&nbsp;<span class="badge-historica">Histórica</span>{% endif %}</span>
                    <i class="bi bi-chevron-right card-arrow"></i>
                </a>
                <button class="fav-btn"
                        data-controller="favorito-btn"
                        data-favorito-btn-type-value="especialidades"
                        data-favorito-btn-id-value="{{ especialidad.id }}"
                        data-favorito-btn-nombre-value="{{ especialidad.nombre }}"
                        data-favorito-btn-href-value="{{ path('app_especialidad_index', { especialidad: especialidad.id }) }}"
                        data-action="click->favorito-btn#toggle"
                        aria-label="Añadir a favoritos"
                        title="Añadir a favoritos">
                    <i class="fav-btn-icon bi bi-star"></i>
                </button>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="text-center py-5 d-none" data-search-target="empty" style="color:var(--sipri-muted)">
        <i class="bi bi-search d-block fs-2 mb-2 opacity-50"></i>
        No se encontraron especialidades con ese criterio
    </div>
</div>
{% endblock %}
