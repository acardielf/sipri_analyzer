{% set countHistorico = cursos|length > 3 ? cursos|length - 3 : 0 %}

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2"
     data-controller="tabla-historico">
    <p class="mb-0 text-secondary small">
        Número de plazas por provincia y curso, con el rango de órdenes de bolsa adjudicados.
    </p>
    {% if countHistorico > 0 %}
        <button class="btn btn-sm btn-outline-secondary"
                data-tabla-historico-target="btn"
                data-action="tabla-historico#toggle">
            Ver cursos anteriores
        </button>
    {% endif %}

<table class="table table-striped table-bordered mt-3">
    <tr>
        <th>Provincia</th>
        {% for curso in cursos %}
            <th {% if loop.index > 3 %}data-tabla-historico-target="col" class="d-none"{% endif %}>
                <span class="d-none d-xl-inline">Curso {{ curso.nombre }}</span>
                <span class="d-inline d-xl-none">{{ curso.simpleLabel }}</span>
            </th>
        {% endfor %}
    </tr>

    <tr>
        <td>
            <strong>Todas</strong>
        </td>
        {% for cursoId, provinciasByCurso in plazasFiltradas %}
            <td {% if loop.index > 3 %}data-tabla-historico-target="col" class="d-none"{% endif %}>
                {% if provinciasByCurso['ALL']['plazas'] > 0 %}
                    <div>
                        <span class="fs-5 fw-bold">{{ provinciasByCurso['ALL']['plazas'] }}</span>
                    </div>
                    <div>
                        <span class="text-secondary" style="font-size:.8em">
                            [{{ provinciasByCurso['ALL']['minOrden'] }} – {{ provinciasByCurso['ALL']['maxOrden'] }}]
                        </span>
                    </div>
                {% else %}
                    <span>–</span>
                {% endif %}
            </td>
        {% endfor %}
    </tr>

    <tr>
        <td colspan="{{ cursos|length + 1 }}"></td>
    </tr>

    {% for provincia in provincias %}
        <tr>
            <td>
                <strong>{{ provincia.nombre }}</strong>
            </td>
            {% for cursoId, provinciasByCurso in plazasFiltradas %}
                <td {% if loop.index > 3 %}data-tabla-historico-target="col" class="d-none"{% endif %}>
                    {% if provinciasByCurso[provincia.id]['plazas'] > 0 %}
                        <div>
                            <a href="{{ path('app_especialidad_detail', {
                                especialidad: especialidad.id,
                                curso: cursoId,
                                provincia: provincia.id
                            }) }}">
                                <span class="fs-5 fw-bold">{{ provinciasByCurso[provincia.id]['plazas'] }}</span>
                            </a>
                        </div>
                        <div>
                            <span class="text-secondary" style="font-size:.8em">
                                [{{ provinciasByCurso[provincia.id]['minOrden'] }} – {{ provinciasByCurso[provincia.id]['maxOrden'] }}]
                            </span>
                        </div>
                    {% else %}
                        <span>–</span>
                    {% endif %}
                </td>
            {% endfor %}
        </tr>
    {% endfor %}

</table>
</div>
