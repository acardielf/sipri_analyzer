{# ── Tabla ────────────────────────────────────────────────────────────────── #}
<div class="tab-plazas-wrap mt-3">
<table class="table table-hover">
    <thead>
        <tr>
            <th class="col-sticky">Provincia</th>
            {% for curso in cursos %}
            <th class="{{ loop.index > 3 ? 'th-hist' : '' }}" style="min-width:95px;width:95px">
                {% if loop.first %}<i class="bi bi-circle-fill me-1" style="font-size:.45rem;vertical-align:middle;opacity:.7"></i>{% endif %}
                <span class="d-none d-xl-inline">Curso {{ curso.nombre }}</span>
                <span class="d-inline d-xl-none">{{ curso.simpleLabel }}</span>
            </th>
            {% endfor %}
        </tr>
    </thead>

    <tbody>

    {# ── Fila "Todas" ─────────────────────────────────────────────────────── #}
    <tr class="tr-todas">
        <td class="col-sticky fw-bold">Todas</td>
        {% for cursoId, byCurso in plazasFiltradas %}
            {% set d = byCurso['ALL'] %}
            <td class="{{ loop.index > 3 ? 'td-hist' : '' }}">
                {% if d.plazas > 0 %}
                    <div class="fw-bold" style="font-size:1.45rem;color:var(--sipri-blue)">{{ d.plazas }}</div>
                    {% if d.maxOrden > 0 %}
                        <div class="range-nums">
                            <span title="Primera posición llamada">[ {{ d.minOrden }}</span>
                            <span style="opacity:.4">-</span>
                            <span title="Última posición llamada">{{ d.maxOrden }} ]</span>
                        </div>
                    {% endif %}
                {% else %}
                    <span class="text-muted">–</span>
                {% endif %}
            </td>
        {% endfor %}
    </tr>

    <tr class="tr-sep"><td colspan="{{ cursos|length + 1 }}"></td></tr>

    {# ── Filas por provincia ───────────────────────────────────────────────── #}
    {% for provincia in provincias %}
    <tr>
        <td class="col-sticky fw-semibold" style="color:var(--sipri-text)">{{ provincia.nombre }}</td>
        {% for cursoId, byCurso in plazasFiltradas %}
            {% set d = byCurso[provincia.id] is defined ? byCurso[provincia.id] : {'plazas':0,'minOrden':0,'maxOrden':0} %}
            <td class="{{ loop.index > 3 ? 'td-hist' : '' }}">
                {% if d.plazas > 0 %}
                    <a href="{{ path('app_especialidad_detail', {
                        especialidad: especialidad.id,
                        curso: cursoId,
                        provincia: provincia.id
                    }) }}" class="fw-bold text-decoration-none" style="font-size:1.25rem;color:var(--sipri-blue)">
                        {{ d.plazas }}
                    </a>
                    {% if d.maxOrden > 0 %}
                        <div class="range-nums">
                            <span title="Primera posición llamada">[ {{ d.minOrden }}</span>
                            <span style="opacity:.4">-</span>
                            <span title="Última posición llamada">{{ d.maxOrden }} ]</span>
                        </div>
                    {% endif %}
                {% else %}
                    <span class="text-muted small">–</span>
                {% endif %}
            </td>
        {% endfor %}
    </tr>
    {% endfor %}

    </tbody>
</table>
</div>
