{% extends 'base.html.twig' %}

{% block title %}Cuerpos docentes{% endblock %}

{% block main_content %}
<div class="page-header">
    <div class="container-fluid">
        <h2><i class="bi bi-collection-fill me-2" style="color:var(--sipri-blue-mid)"></i>Cuerpos docentes</h2>
    </div>
</div>

<div class="container-fluid pb-5">

    {# ── Mis especialidades favoritas ──────────────────────────────────────── #}
    <div data-controller="mis-favoritos" class="mb-4">
        <div data-mis-favoritos-target="seccion" class="mis-fav-seccion d-none">
            <div class="mis-fav-header">
                <i class="bi bi-star-fill mis-fav-icon"></i>
                <span class="mis-fav-title">Mis especialidades favoritas</span>
                <span class="mis-fav-hint">Haz clic para ir directamente a la especialidad</span>
            </div>
            <div data-mis-favoritos-target="lista" class="mis-fav-lista"></div>
        </div>
    </div>

    {# ── Lista de cuerpos ──────────────────────────────────────────────────── #}
    <div data-controller="search">
        <div class="row mb-4 align-items-center">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="search"
                           class="form-control search-input"
                           placeholder="Filtrar por código o nombre…"
                           autocomplete="off"
                           data-search-target="input"
                           data-action="input->search#filter">
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-8 mt-2 mt-md-0 text-md-end search-count">
                <span data-search-target="count">{{ cuerpos|length }}</span> cuerpos
            </div>
        </div>

        <div class="row g-3">
            {% for cuerpo in cuerpos %}
            <div class="col-12 col-md-6 col-xl-4"
                 data-search-target="item"
                 data-search-terms="{{ cuerpo.id|lower }} {{ cuerpo.nombre|lower }}">
                <a href="{{ path('app_lista_especialidades', { cuerpo: cuerpo.id }) }}" class="card-sipri">
                    <span class="card-code">{{ cuerpo.id }}</span>
                    <span class="card-name">{{ cuerpo.nombre }}</span>
                    <i class="bi bi-chevron-right card-arrow"></i>
                </a>
            </div>
            {% endfor %}
        </div>

        <div class="text-center py-5 d-none" data-search-target="empty" style="color:var(--sipri-muted)">
            <i class="bi bi-search d-block fs-2 mb-2 opacity-50"></i>
            No se encontraron cuerpos con ese criterio
        </div>
    </div>

</div>
{% endblock %}
