{% extends 'base.html.twig' %}

{% block title %}Curso {{ curso.nombre }} – Convocatorias{% endblock %}

{% block main_content %}

{# JSON para el calendario Stimulus #}
<script type="application/json" id="cal-data">{{ calData|json_encode(constant('JSON_HEX_TAG'))|raw }}</script>

<div class="page-header">
    <div class="container-fluid">
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_index') }}"><i class="bi bi-house-fill me-1"></i>Inicio</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_convocatoria_index') }}">Convocatorias</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ curso.nombre }}</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <h2 class="mb-0" style="color:var(--sipri-blue);font-weight:700">
                <i class="bi bi-calendar3 me-2"></i>Curso {{ curso.nombre }}
            </h2>
            <div style="display:flex;gap:1rem;font-size:.9rem;color:var(--sipri-muted)">
                <span><strong style="color:var(--sipri-blue)">{{ total }}</strong> convocatoria{{ total != 1 ? 's' }}</span>
                <span><strong style="color:var(--sipri-blue)">{{ totalPlazas|number_format(0, ',', '.') }}</strong> plazas</span>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid py-4 pb-5"
     data-controller="calendario-convocatorias">

    {# El controlador Stimulus renderiza aquí directamente (un solo curso) #}
    <div data-calendario-convocatorias-target="resumen" class="mb-1"></div>
    <div data-calendario-convocatorias-target="calendar"></div>
    <div data-calendario-convocatorias-target="lista" class="mt-3"></div>

</div>

{% endblock %}
