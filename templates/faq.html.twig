{% extends 'base.html.twig' %}

{% block title %}Preguntas frecuentes – Analizador SIPRI{% endblock %}

{% block main_content %}

    <div class="page-header">
        <div class="container-fluid">
            <nav aria-label="breadcrumb" class="mb-1">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_index') }}"><i class="bi bi-house-fill me-1"></i>Inicio</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Preguntas frecuentes</li>
                </ol>
            </nav>
            <h2><i class="bi bi-question-circle-fill me-2"></i>Preguntas frecuentes</h2>
        </div>
    </div>

    <div class="container py-5 pb-6" style="max-width:820px">

        <div class="faq-accordion" id="preguntas">

            {% set preguntas = [
                {
                    'id':    'faq-fiabilidad',
                    'icon':  'bi-shield-exclamation',
                    'q':     '¿Es oficial y completamente fiable la información?',
                    'open':  true
                },
                {
                    'id':    'faq-porque',
                    'icon':  'bi-heart',
                    'q':     '¿Por qué he hecho esta página?',
                    'open':  false
                },
                {
                    'id':    'faq-tecnologia',
                    'icon':  'bi-cpu',
                    'q':     '¿Cómo se obtienen los datos? ¿Qué tecnología se usa?',
                    'open':  false
                },
                {
                    'id':    'faq-legal',
                    'icon':  'bi-lock',
                    'q':     'Información legal y protección de datos',
                    'open':  false
                },
                {
                    'id':    'faq-historicas',
                    'icon':  'bi-archive',
                    'q':     '¿Qué son las especialidades históricas?',
                    'open':  false
                },
                {
                    'id':    'faq-problemas',
                    'icon':  'bi-exclamation-triangle',
                    'q':     'Problemas conocidos',
                    'open':  false
                },
                {
                    'id':    'faq-actualizacion',
                    'icon':  'bi-arrow-repeat',
                    'q':     '¿Cada cuánto se actualizan los datos?',
                    'open':  false
                },
                {
                    'id':    'faq-contacto',
                    'icon':  'bi-chat-dots',
                    'q':     'He encontrado un problema o tengo una sugerencia',
                    'open':  false
                }
            ] %}

            {% for item in preguntas %}
                <div class="faq-item">
                    <button class="faq-btn {{ item.open ? '' : 'collapsed' }}"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#{{ item.id }}"
                            aria-expanded="{{ item.open ? 'true' : 'false' }}"
                            aria-controls="{{ item.id }}">
                <span class="faq-btn-icon">
                    <i class="bi {{ item.icon }}"></i>
                </span>
                        <span class="faq-btn-text">{{ item.q }}</span>
                        <i class="bi bi-chevron-down faq-chevron"></i>
                    </button>
                    <div id="{{ item.id }}" class="collapse {{ item.open ? 'show' : '' }}">
                        <div class="faq-body">

                            {% if item.id == 'faq-fiabilidad' %}
                                <p>
                                    <strong>No.</strong> El único lugar oficial para las convocatorias son las
                                    resoluciones
                                    publicadas periódicamente en
                                    <a href="https://sipri.juntadeandalucia.es/sipri/inicio/" target="_blank"
                                       rel="noopener">la web de SIPRI</a>
                                    de la Consejería de Desarrollo Educativo y Formación Profesional de la Junta de
                                    Andalucía.
                                </p>
                                <p class="mb-0">
                                    Los datos que aquí se muestran pueden tener errores, puesto que el procesamiento se
                                    hace
                                    de forma automática <strong>sin revisión humana</strong>. Consulta la sección de
                                    <em>Problemas conocidos</em>
                                    de esta misma página.
                                </p>


                            {% elseif item.id == 'faq-porque' %}
                                <p>
                                    Cada curso, miles de docentes se ven obligados a
                                    vivir sin saber si van a trabajar la semana siguiente ni en qué provincia acabarán.
                                    Esa incertidumbre no solo redunda en un problema personal,
                                    familiar y de conciliación que merma las esperanzas y la estabilidad de nuestro personal docente:
                                    Además, dificulta la planificación de los centros, genera inestabilidad en las aulas
                                    y pone en riesgo la calidad de la escuela pública.
                                </p>
                                <p>
                                    SIPRI es un sistema que publica la información de las convocatorias en PDF,
                                    pero sin agruparlas por
                                    especialidad ni permitir un análisis histórico sencillo. Esta herramienta nació
                                    para cubrir esa necesidad: consultar las plazas por especialidad, seguir las
                                    posiciones de bolsa llamadas a lo largo del curso y ver la evolución entre años.
                                </p>
                                <p>
                                    Estoy afiliado a <a href="https://ustea.org/" target="_blank"
                                                        rel="noopener"><strong>USTEA</strong></a>,
                                    y este proyecto altruista forma parte de mi compromiso con la escuela pública y con
                                    el
                                    software libre.
                                </p>
                                <p>
                                    Estar afiliado a un sindicato es fundamental porque nos da fuerzas y herramientas
                                    para
                                    defender la escuela pública. No se trata únicamente de mejorar nuestras condiciones
                                    laborales, sino de
                                    luchar por una educación gratuita, inclusiva y de calidad para todos y todas. Busca
                                    el que mejor
                                    represente tus intereses e ideales y únete a la lucha de la educación pública.
                                </p>


                            {% elseif item.id == 'faq-tecnologia' %}
                                <ul class="faq-list">
                                    <li>Los datos se obtienen de los <strong>anexos oficiales publicados en
                                            SIPRI</strong> en PDF mediante una
                                        aplicación desarrollada en PHP / Symfony.
                                    </li>
                                    <li>Utiliza un wrapper de Python de <a href="https://tabula.technology/"
                                                                           target="_blank"
                                                                           rel="noopener"><code>Tabula</code></a>
                                        para extraer las tablas de los PDFs de las convocatorias.
                                    </li>
                                    <li>Diariamente, la librería <code>Stenope</code> genera los archivos
                                        estáticos
                                        que se publican en el repositorio.
                                    </li>
                                    <li>El código fuente está disponible en
                                        <a href="https://github.com/acardielf/sipri_analyzer" target="_blank"
                                           rel="noopener">
                                            <i class="bi bi-github me-1"></i>GitHub</a>.
                                        Animo a que creen issues o pull requests.
                                    </li>
                                </ul>

                            {% elseif item.id == 'faq-legal' %}
                                <p>
                                    Este sitio web es estático y no almacena, recoge ni procesa ningún tipo de
                                    información
                                    personal en ningún servidor. No se hace uso de cookies y no se rastrea su uso de
                                    ninguna forma.
                                </p>
                                <p>
                                    En lo relativo a las adjudicaciones se omite premeditadamente todo dato que suponga
                                    vinculación individual con datos personales de las personas adjudicatarias.
                                </p>
                                <p>
                                    La funcionalidad de <strong>especialidades favoritas y provincias
                                        preferidas</strong>
                                    guarda esos datos exclusivamente en el <code>localStorage</code> del navegador,
                                    sin que salgan en ningún momento del dispositivo del usuario.
                                </p>
                                <p class="mb-0">
                                    El creador de este sitio es Ángel Cardiel Ferrero —
                                    <code>angel.cardiel@protonmail.com</code>.
                                    Los datos proceden de los directorios públicos de la Consejería de Desarrollo
                                    Educativo
                                    de la Junta de Andalucía. La web se aloja en GitHub Pages.
                                </p>

                            {% elseif item.id == 'faq-historicas' %}
                                <p>
                                    Se marca como <span class="badge-historica">Histórica</span> cualquier especialidad
                                    que
                                    no ha tenido plazas ofertadas en ninguna de las convocatorias de los dos últimos
                                    cursos académicos.
                                </p>
                                <p>Esto ocurre en varios supuestos:</p>
                                <ul class="faq-list">
                                    <li><strong>Especialidades creadas durante el COVID-19</strong> (cursos 2019/20 y
                                        2020/21)
                                        para cubrir necesidades extraordinarias que no se han vuelto a convocar.
                                    </li>
                                    <li><strong>Especialidades fusionadas o reconvertidas</strong> en otras
                                        denominaciones
                                        al actualizarse los catálogos de cuerpos docentes.
                                    </li>
                                    <li><strong>Especialidades extinguidas</strong> o con bolsa agotada sin previsión de
                                        nuevas convocatorias.
                                    </li>
                                </ul>
                                <p class="mb-0">
                                    Sus datos históricos siguen siendo accesibles. En el listado de especialidades de
                                    cada
                                    cuerpo están ocultas por defecto; puedes mostrarlas con el botón <em>Ver
                                        históricas</em>.
                                </p>

                            {% elseif item.id == 'faq-problemas' %}
                                <ul class="faq-list mb-2">
                                    <li>Existen adjudicaciones a centros <strong>OCEP</strong> que no aparecen en los
                                        listados finales.
                                    </li>
                                    <li>La determinación de si una plaza ha quedado desierta no siempre es precisa.</li>
                                </ul>
                                <p class="mb-0 text-muted small">En caso de detectar nuevos problemas se irán detallando
                                    en esta sección.</p>

                            {% elseif item.id == 'faq-actualizacion' %}
                                <p>
                                    Los datos proceden de los anexos PDF publicados en SIPRI. A medida que la Junta
                                    publica
                                    nuevas convocatorias, se procesan y actualizan los datos automáticamente.

                                </p>

                            {% elseif item.id == 'faq-contacto' %}
                                <p>
                                    Puedes contactar en <code>angel.cardiel@protonmail.com</code>.
                                </p>
                                <p class="mb-0">
                                    El código fuente está disponible en
                                    <a href="https://github.com/acardielf/sipri_analyzer" target="_blank"
                                       rel="noopener">
                                        <i class="bi bi-github me-1"></i>GitHub</a>.
                                    Puedes crear un <em>issue</em> o un <em>pull request</em> si detectas algo
                                    o quieres colaborar.
                                </p>
                            {% endif %}

                        </div>
                    </div>
                </div>
            {% endfor %}

        </div>
    </div>

{% endblock %}
